# ============================================================
# AI Business Inspector — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Gumroad Product URLs
# Set these to your Gumroad product checkout links
NEXT_PUBLIC_GUMROAD_QUICK_SCAN_URL=https://gumroad.com/l/GUMROAD_QUICK_SCAN_URL
NEXT_PUBLIC_GUMROAD_GROWTH_AUDIT_URL=https://gumroad.com/l/GUMROAD_GROWTH_AUDIT_URL
NEXT_PUBLIC_GUMROAD_REVENUE_AUDIT_URL=https://gumroad.com/l/GUMROAD_REVENUE_AUDIT_URL

# n8n Webhook URL
# Set this to your n8n webhook endpoint
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/ai-business-inspector

# Site URL (used for SEO/OpenGraph)
NEXT_PUBLIC_SITE_URL=https://aibusinessinspector.com
